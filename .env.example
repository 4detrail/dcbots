# Discord Bot Ayarları (artik sunucuya ozel bilgi YOK - bot cok-sunuculu calisir)
DISCORD_TOKEN=BOTUNUN_TOKENI_BURAYA
CLIENT_ID=UYGULAMA_ID_SI_BURAYA
# Developer Portal > Genel Bilgi > "Uygulama ID'si" alanindan al

# Anthropic API (yapay zeka destekli tehlike tespiti icin)
# https://console.anthropic.com adresinden alabilirsin
ANTHROPIC_API_KEY=SENIN_ANTHROPIC_API_KEYIN

# Firebase Admin SDK (Firebase Console > Project Settings > Service Accounts > Generate new private key)
# Indirdigin JSON dosyasinin TAMAMINI tek satir string olarak buraya yapistir
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account", "...": "..."}
FIREBASE_PROJECT_ID=hexages-games-proje-id
